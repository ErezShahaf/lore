{
  "name": "lore",
  "version": "0.1.0",
  "description": "AI-powered thought capture and recall desktop app",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build:app": "vite build",
    "build": "npm run build:icons && tsc --noEmit && vite build && electron-builder",
    "build:icons": "electron-icon-builder --input=resources/icon.png --output=resources --flatten",
    "build:win": "npm run build:icons && tsc --noEmit && vite build && electron-builder --win",
    "build:mac": "npm run build:icons && tsc --noEmit && vite build && electron-builder --mac",
    "build:linux": "tsc --noEmit && vite build && electron-builder --linux",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "reset-db": "node scripts/reset-db.mjs",
    "reset-db:dev": "node scripts/reset-db.mjs --profile dev",
    "reset-db:eval": "node scripts/reset-db.mjs --profile eval",
    "eval:promptfoo": "node scripts/run-promptfoo.mjs",
    "eval:promptfoo:smoke": "node scripts/run-promptfoo.mjs --suite smoke",
    "eval:promptfoo:summary": "node scripts/summarize-promptfoo-results.mjs"
  },
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.lore.app",
    "productName": "Lore",
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "resources/icons/icon.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "artifactName": "${productName}-${version}.${ext}"
    }
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.26.2",
    "apache-arrow": "^18.1.0",
    "electron-ollama": "^0.1.25",
    "pino": "^10.3.1",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "electron": "^41.0.2",
    "electron-builder": "^25.1.8",
    "electron-icon-builder": "^2.0.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "lucide-react": "^0.475.0",
    "promptfoo": "^0.121.2",
    "tailwind-merge": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.2.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vitest": "^3.0.0"
  }
}
